<para><programlisting filename=".c"><codeline><highlight class="keywordtype">void</highlight><highlight class="normal"><sp/><ref refid="port__system_8h_1a5dcdf1cde8372fa1893e1c8f2baf6e55" kindref="member">port_system_power_sleep</ref>()</highlight></codeline>
