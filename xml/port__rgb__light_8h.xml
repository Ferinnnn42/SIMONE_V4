        <name>port_rgb_light_set_rgb</name>
        <param>
          <type>uint8_t</type>
          <declname>rgb_light_id</declname>
        </param>
        <param>
          <type><ref refid="structrgb__color__t" kindref="compound">rgb_color_t</ref></type>
